# Backend base URL for client-side fetches/SSE (public).
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Backend base URL for Server Component / Route Handler fetches. May equal the
# public one; lets server traffic use an internal address. Falls back to
# NEXT_PUBLIC_API_BASE_URL if unset.
API_BASE_URL=http://localhost:8000

# GitHub OAuth client id — used to build the authorize URL (public, not secret).
NEXT_PUBLIC_GITHUB_OAUTH_CLIENT_ID=

# GitHub App slug — used to build the install / "add repositories" link.
NEXT_PUBLIC_GITHUB_APP_SLUG=

# NOTE: no secrets belong here. The OAuth client secret, GitHub App private key,
# webhook secret, and model API keys live only in the backend (revet_be).
